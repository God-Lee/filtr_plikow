{
  "appId": "pl.ekoinbud.filefilter",
  "productName": "Filtr Plikow",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "assets",
      "to": "assets"
    }
  ],
  "win": {
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "portable": {
    "artifactName": "Filtr-Plikow-${version}.exe"
  }
}
